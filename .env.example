# Copy file này thành .env và điền thông tin thực tế
# cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_USER=admin
MYSQL_PASSWORD=your_password
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASES=RepresentativeOffice

# Airflow
AIRFLOW_UID=50000

# PostgreSQL (pgsql - data warehouse DB)
POSTGRES_HOST=pgsql
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password
POSTGRES_DB=postgres
POSTGRES_HOST_AUTH_METHOD=trust
